---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  showProgress?: boolean;
}
const { title, description = 'Blog của Ngô Phú Cường — công nghệ, AI, và những thứ thật.', showProgress = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body>
  {showProgress && <div id="progress-bar"></div>}

  <header class="site-header">
    <div class="container">
      <nav class="site-nav">
        <a href="/">Trang chủ</a>
        <a href="/about">Về tôi</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      © {new Date().getFullYear()} Ngô Phú Cường &nbsp;·&nbsp;
      <a href="mailto:info@cuong.ngo">info@cuong.ngo</a>
    </div>
  </footer>

  {showProgress && (
    <script>
      const bar = document.getElementById('progress-bar');
      if (bar) {
        window.addEventListener('scroll', () => {
          const total = document.body.scrollHeight - window.innerHeight;
          bar.style.width = total > 0 ? (window.scrollY / total * 100) + '%' : '0%';
        }, { passive: true });
      }
    </script>
  )}
  {showProgress && (
    <script is:inline>
      const trackingBase = 'https://signals.cuong.ngo/api/track';
      const path = window.location.pathname;

      if (path.startsWith('/bai/')) {
        const slug = path.replace(/^\/bai\//, '').replace(/\/$/, '');
        const payload = JSON.stringify({
          slug,
          path,
          title: document.title,
        });

        try {
          if (navigator.sendBeacon) {
            navigator.sendBeacon(trackingBase, new Blob([payload], { type: 'application/json' }));
          } else {
            fetch(trackingBase, {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: payload,
              keepalive: true,
              mode: 'cors',
            });
          }
        } catch {}
      }
    </script>
  )}
</body>
</html>
