---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title={post.data.title} description={post.data.description} showProgress={true}>
  <div class="container">
    <article>
      <header class="article-header">
        <h1>{post.data.title}</h1>
        <p class="article-meta">
          {formatDate(post.data.date)}
          {post.data.readTime && <> · {post.data.readTime}</>}
        </p>
      </header>
      <div class="article-body">
        <Content />
      </div>
    </article>

    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
      <a href="/" style="font-family: var(--font-mono); font-size: 0.8rem; text-decoration: none; color: var(--color-ink-2);">← Về trang chủ</a>
    </div>
  </div>
</Base>
