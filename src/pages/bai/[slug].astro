---
import Base from '../../layouts/Base.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ConnectBlock from '../../components/ConnectBlock.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');

// Bài cùng tuyến — sắp theo seriesOrder
const seriesPosts = post.data.series
  ? allPosts
      .filter(p => p.data.series === post.data.series)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];

// Bài liên quan — resolve từ relatedSlugs
const relatedPosts = post.data.relatedSlugs
  ? allPosts.filter(p => post.data.relatedSlugs!.includes(p.id)).slice(0, 2)
  : [];

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title={post.data.title} description={post.data.description} showProgress={true}>
  <div class="container">
    <article>
      <header class="article-header">
        {post.data.series && post.data.seriesTitle && (
          <span class="series-label">
            Bài {post.data.seriesOrder ?? ''} trong tuyến · {post.data.seriesTitle}
          </span>
        )}
        <h1>{post.data.title}</h1>
        {post.data.description && (
          <p class="article-standfirst">{post.data.description}</p>
        )}
        <p class="article-meta">
          {formatDate(post.data.date)}
          {post.data.readTime && <> · {post.data.readTime}</>}
        </p>
        {post.data.tags && post.data.tags.length > 0 && (
          <ul class="tag-list">
            {post.data.tags.map(tag => <li>{tag}</li>)}
          </ul>
        )}
      </header>

      <div class="article-body">
        <Content />
      </div>
    </article>

    {/* Thứ tự cuối bài theo spec:
        1. Câu hỏi mở — nằm trong nội dung bài (tác giả viết)
        2. ConnectBlock (nếu có callToAction)
        3. SeriesNav (nếu thuộc tuyến)
        4. RelatedPosts (nếu có relatedSlugs)
        5. Hyvor Talk (comments) */}

    {post.data.callToAction && (
      <ConnectBlock callToAction={post.data.callToAction} />
    )}

    {seriesPosts.length > 1 && (
      <SeriesNav
        currentSlug={post.id}
        seriesTitle={post.data.seriesTitle ?? post.data.series ?? ''}
        seriesPosts={seriesPosts}
      />
    )}

    {relatedPosts.length > 0 && (
      <RelatedPosts posts={relatedPosts} />
    )}

    {/* Hyvor Talk comments */}
    <div style="margin-top: 3rem;">
      <div id="hyvor-talk-view"></div>
      <script type="text/javascript">
        var HYVOR_TALK_WEBSITE = "YOUR_WEBSITE_ID";
        var HYVOR_TALK_CONFIG = { url: false, id: false };
      </script>
      <script
        async
        type="text/javascript"
        src="//talk.hyvor.com/web-api/embed"
      ></script>
    </div>

    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
      <a href="/" style="font-family: var(--font-mono); font-size: 0.8rem; text-decoration: none; color: var(--color-ink-2);">← Về trang chủ</a>
    </div>
  </div>
</Base>
