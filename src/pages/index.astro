---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title="cuong.ngo">
  <div class="container">
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          {post.data.series && post.data.seriesTitle && (
            <span class="series-label">
              Bài {post.data.seriesOrder ?? ''} trong tuyến · {post.data.seriesTitle}
            </span>
          )}
          <a class="post-title" href={`/bai/${post.id}`}>{post.data.title}</a>
          <p class="post-meta">
            {formatDate(post.data.date)}
            {post.data.readTime && <> · {post.data.readTime}</>}
          </p>
          <p class="post-desc">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="tag-list">
              {post.data.tags.map(tag => <li>{tag}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</Base>
