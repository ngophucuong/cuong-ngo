---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title="cuong.ngo">
  <div class="container">
    <section class="home-hero">
      <div class="home-hero-copy">
        <p class="tagline">Công nghệ, AI, và những thứ thật.</p>
        <p class="intro">
          Tôi là Ngô Phú Cường — làm phần mềm từ thời máy 386, nay chuyên chữa pain point thật cho doanh nghiệp bằng AI.
          Trang này là nơi tôi ghi lại những gì học được — không phải để dạy, mà để nghĩ thành tiếng.
        </p>
      </div>

      <figure class="home-hero-figure">
        <img
          src="/images/chan-dung.png"
          alt="Chân dung Ngô Phú Cường"
          class="home-portrait"
          width="900"
          height="1200"
        />
      </figure>
    </section>

    <ul class="post-list">
      {posts.map((post) => (
        <li>
          {post.data.series && post.data.seriesTitle && (
            <span class="series-label">
              Bài {post.data.seriesOrder ?? ''} trong tuyến · {post.data.seriesTitle}
            </span>
          )}
          <a class="post-title" href={`/bai/${post.id}`}>{post.data.title}</a>
          <p class="post-meta">
            {formatDate(post.data.date)}
            {post.data.readTime && <> · {post.data.readTime}</>}
          </p>
          <p class="post-desc">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="tag-list">
              {post.data.tags.map(tag => <li>{tag}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</Base>
